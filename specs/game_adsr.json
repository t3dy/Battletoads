{
  "_description": "Per-game ADSR presets for keyboard play. These are APPROXIMATIONS of the CC11 envelope data. CC-driven playback uses the actual per-frame data, not these values.",
  "_authority": "APPROXIMATION — lower authority than CC11 data in MIDI files",
  "presets": {
    "MegaMan": {
      "pulse1":   {"duty": 3, "atk": 0, "dec": 300, "sus": 12, "rel": 50, "duty_end": 3},
      "pulse2":   {"duty": 3, "atk": 0, "dec": 400, "sus": 14, "rel": 50, "duty_end": 3},
      "triangle": {"atk": 0, "rel": 30},
      "noise":    {"atk": 0, "dec": 80},
      "notes": "Minimal 2-step envelope (64>16). 1-frame arpeggios on P2."
    },
    "Castlevania": {
      "pulse1":   {"duty": 1, "atk": 50, "dec": 0, "sus": 4, "rel": 40, "duty_end": 1},
      "pulse2":   {"duty": 2, "atk": 0, "dec": 120, "sus": 1, "rel": 30, "duty_end": 2},
      "triangle": {"atk": 0, "rel": 40},
      "noise":    {"atk": 0, "dec": 120},
      "notes": "Fast 4-step decay (32>24>16>8). Percussive, driving feel."
    },
    "CastlevaniaII": {
      "pulse1":   {"duty": 2, "atk": 0, "dec": 200, "sus": 10, "rel": 60, "duty_end": 2},
      "pulse2":   {"duty": 1, "atk": 0, "dec": 150, "sus": 8, "rel": 50, "duty_end": 1},
      "triangle": {"atk": 0, "rel": 50},
      "noise":    {"atk": 0, "dec": 100},
      "notes": "Slower decay than CV1, more sustained."
    },
    "Metroid": {
      "pulse1":   {"duty": 2, "atk": 20, "dec": 0, "sus": 6, "rel": 80, "duty_end": 2},
      "pulse2":   {"duty": 2, "atk": 20, "dec": 0, "sus": 6, "rel": 80, "duty_end": 2},
      "triangle": {"atk": 0, "rel": 60},
      "noise":    {"atk": 0, "dec": 150},
      "notes": "APPROXIMATION ONLY. Real envelope is crescendo-decrescendo (impossible with standard ADSR). CC11 required for fidelity."
    }
  }
}
